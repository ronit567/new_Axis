# Copy this file to .env and fill in the values from your Supabase project
# (Project Settings → API). Do not commit .env — it is gitignored.
#
# EXPO_PUBLIC_* vars are inlined into the JS bundle at build time, so restart
# the Expo dev server after changing them.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
